# Local development settings. Never commit a real secret.
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:8000

# Create your own key at https://platform.openai.com/api-keys
OPENAI_API_KEY=replace-with-your-own-openai-key
OPENAI_MODEL=gpt-5.5
OPENAI_MAX_OUTPUT_TOKENS=4096
OPENAI_TIMEOUT_SECONDS=90
OPENAI_MAX_RETRIES=3
OPENAI_MAX_FILE_BYTES=10485760
OPENAI_MAX_IMAGE_PX=6000
MAX_EXTRACTED_TEXT_CHARS=60000
MAX_UPLOAD_BYTES=26214400

DATABASE_URL=sqlite:///./data/mikro_busway.db
