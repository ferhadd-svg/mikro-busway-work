# Local development settings. Never commit a real secret.
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:8000

# Create your own key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=replace-with-your-own-anthropic-key
CLAUDE_MODEL=claude-sonnet-5
CLAUDE_MAX_TOKENS=4096
CLAUDE_TIMEOUT_SECONDS=90
CLAUDE_MAX_RETRIES=3
CLAUDE_MAX_FILE_BYTES=10485760
CLAUDE_MAX_IMAGE_PX=2000
MAX_EXTRACTED_TEXT_CHARS=60000
MAX_UPLOAD_BYTES=26214400

DATABASE_URL=sqlite:///./data/mikro_busway.db
