# Copy this file to .env and fill in your values

# Required — get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides (defaults shown)
# CLAUDE_MODEL=claude-sonnet-4-6
# DATABASE_URL=sqlite:///./data/mikro_busway.db

# Auth — optional. Session cookies are DB-backed random tokens (not signed
# by SECRET_KEY), so leaving this at the default has no impact on session
# security; it's kept only as a general-purpose app secret for future use.
# SECRET_KEY=change-me-to-a-random-string
#
# Set to true once the app is served over HTTPS in production (Render).
# Leave false for local http:// development.
# COOKIE_SECURE=true
